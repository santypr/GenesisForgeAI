{
  "name": "genesisforgeai-extension",
  "displayName": "GenesisForgeAI",
  "description": "VS Code extension for GenesisForgeAI agents, skills, and automated project bootstrap.",
  "version": "0.0.1",
  "publisher": "santiago",
  "license": "SEE LICENSE IN LICENSE.md",
  "repository": {
    "type": "git",
    "url": "https://github.com/santypr/GenesisForgeAI.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "scripts": {
    "sync:resources": "node ./scripts/sync-resources.js",
    "postinstall": "npm run sync:resources",
    "vscode:prepublish": "npm run sync:resources",
    "package": "vsce package --no-yarn"
  },
  "devDependencies": {
    "@vscode/vsce": "^2.27.0"
  },
  "categories": ["Other"],
  "files": [
    "src/**",
    "prompts/**",
    "assets/**",
    "scripts/**",
    "resources/**",
    "README.md",
    "LICENSE.md",
    "package.json"
  ],
  "main": "./src/extension.js",
  "activationEvents": [
    "onCommand:genesisForge.bootstrap",
    "onCommand:genesisForge.initProject",
    "onCommand:genesisForge.addTechnologies",
    "onCommand:genesisForge.runAgent",
    "onCommand:genesisForge.runSkill",
    "onCommand:genesisForge.generateDocumentation",
    "onCommand:genesisForge.createTaskFolder"
  ],
  "contributes": {
    "commands": [
      { "command": "genesisForge.bootstrap", "title": "GenesisForgeAI" },
      { "command": "genesisForge.initProject", "title": "GenesisForgeAI: Init Project" },
      { "command": "genesisForge.addTechnologies", "title": "GenesisForgeAI: Add Technologies" },
      { "command": "genesisForge.runAgent", "title": "GenesisForgeAI: Run Agent" },
      { "command": "genesisForge.runSkill", "title": "GenesisForgeAI: Run Skill" },
      { "command": "genesisForge.generateDocumentation", "title": "GenesisForgeAI: Generate Documentation" },
      { "command": "genesisForge.createTaskFolder", "title": "GenesisForgeAI: Create Task Folder" }
    ],
    "views": {
      "explorer": [
        { "id": "genesisForge.projectManifest", "name": "Project Manifest" },
        { "id": "genesisForge.agents", "name": "Agents" },
        { "id": "genesisForge.skills", "name": "Skills" },
        { "id": "genesisForge.docsStatus", "name": "Documentation Status" }
      ]
    }
  }
}
